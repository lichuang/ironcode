# IronCode Configuration Example
# Copy this file to ~/.ironcode/config.toml or ./ironcode.toml

# =============================================================================
# Data Directory - Root directory for ironcode data files
# =============================================================================

# Data directory for ironcode files (logs, prompts, etc.)
# If not specified, defaults to ~/.ironcode/
# 
# When specified, the following paths will be resolved relative to this directory:
# - prompts/         : Directory containing system prompt templates
# - logs/            : Directory containing log files
#
# Note: This config file itself should be located at either:
# - ~/.ironcode/config.toml (default), or
# - A location specified via -c/--config command line option
#
# dir = "~/.ironcode"

# =============================================================================
# Default Model - Which model to use by default
# =============================================================================

# Default model to use (must match a key in [models] section)
# Format: "provider-name/model-name" or just "model-name"
default_model = "openai/gpt-4o"

# =============================================================================
# Providers - Define LLM API endpoints
# A provider can be shared by multiple models
# =============================================================================

# All providers use OpenAI-compatible API
# This includes OpenAI official, Azure OpenAI, Ollama, and other compatible providers

[providers.openai]
type = "openai-compatible"
base_url = "https://api.openai.com/v1"
api_key = "${OPENAI_API_KEY}"

[providers.azure]
type = "openai-compatible"
base_url = "https://your-resource.openai.azure.com/openai/deployments"
api_key = "${AZURE_OPENAI_API_KEY}"
api_version = "2024-02-01"

[providers.ollama]
type = "openai-compatible"
base_url = "http://localhost:11434/v1"
# No api_key needed for local Ollama

[providers.siliconflow]
type = "openai-compatible"
base_url = "https://api.siliconflow.cn/v1"
api_key = "${SILICONFLOW_API_KEY}"

[providers.deepseek]
type = "openai-compatible"
base_url = "https://api.deepseek.com/v1"
api_key = "${DEEPSEEK_API_KEY}"

# =============================================================================
# Models - Define available models and their settings
# Each model references a provider by name
# =============================================================================

[models."openai/gpt-4o"]
provider = "openai"
model = "gpt-4o"
max_context_size = 128000
temperature = 0.7
max_tokens = 4096
supports_streaming = true
supports_vision = true

[models."openai/gpt-4o-mini"]
provider = "openai"
model = "gpt-4o-mini"
max_context_size = 128000
temperature = 0.7
max_tokens = 4096
supports_streaming = true
supports_vision = true

[models."azure/gpt-4"]
provider = "azure"
model = "gpt-4-deployment"
max_context_size = 8192
temperature = 0.7
max_tokens = 4096
supports_streaming = true

[models."local/llama3.1"]
provider = "ollama"
model = "llama3.1"
max_context_size = 128000
temperature = 0.7
max_tokens = 4096
supports_streaming = true

[models."siliconflow/deepseek-v3"]
provider = "siliconflow"
model = "deepseek-ai/DeepSeek-V3"
max_context_size = 64000
temperature = 0.7
max_tokens = 4096
supports_streaming = true

[models."deepseek/deepseek-chat"]
provider = "deepseek"
model = "deepseek-chat"
max_context_size = 64000
temperature = 0.7
max_tokens = 4096
supports_streaming = true

# =============================================================================
# Logging
# =============================================================================

[logging]
level = "info"        # Options: "trace", "debug", "info", "warn", "error"

# Logs are always written to ${dir}/logs/ironcode.log
# where ${dir} is the data directory specified above (defaults to ~/.ironcode/)
# 
# To output logs to stderr instead of file, set the RUST_LOG environment variable:
#   RUST_LOG=debug ironcode
